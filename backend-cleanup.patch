+# === Base de datos ===
+# Cadena de conexión a PostgreSQL. En desarrollo local con docker-compose,
+# coincide con los valores definidos en docker-compose.yml.
+DATABASE_URL="postgresql://barberflow:barberflow_password@localhost:5432/barberflow"
+
+# === Autenticación ===
+# Secreto usado para firmar y verificar los JWT. OBLIGATORIO — la API no
+# arranca sin esta variable configurada.
+# Genera uno propio con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
+# Nunca lo compartas ni lo subas al repositorio real (.env está en .gitignore).
+JWT_SECRET=""
+
+# === Servidor ===
+# Puerto en el que escucha la API de NestJS. Next.js (apps/web) también usa
+# el puerto 3000 por defecto con `next dev`, así que se recomienda separar
+# la API en un puerto distinto para evitar colisiones en desarrollo local.
+PORT=3001
